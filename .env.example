# Shared secret that Notify must send in the X-Internal-Secret header.
# Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=change_this_to_a_long_random_string

# Optional: route the WhatsApp connection through a SOCKS proxy so it exits a
# residential IP (e.g. a Tailscale exit node on a phone). Leave empty to connect
# directly. Example: socks5h://127.0.0.1:1055
WAB_PROXY=
